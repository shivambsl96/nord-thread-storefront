.DS_Store
*.zip

# Local secrets and generated environment files
**/.env
**/.env.*
!**/.env.example

# JavaScript build output and dependencies
**/node_modules/
**/.next/
**/out/

# Terraform local state must not be committed
**/.terraform/
**/.terraform.lock.hcl
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
!**/*.tfvars.example

# Unrelated local workspace folders/files
/README.md
/backend/
/idm_inspect/
/macidm/
/main.tf
/modules/
/outputs.tf
/providers.tf
/variables.tf
/versions.tf
